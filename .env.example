# Telegram Bot Token
API_KEY="YOUR_TELEGRAM_BOT_TOKEN_HERE"
TELEGRAM_TOKEN=${API_KEY}

# Admin Telegram User IDs (integer IDs, separated by comma)
ADMIN1=
ADMIN2=

# Database Configuration
# Default: SQLite (no config needed)
DATABASE_URL=sqlite:////app/data/rollcall.db

# OR for PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/rollcall_db

# Health Check Configuration
HEALTH_CHECK_PORT=8080
