# ============================================================================
# RollCall — environment configuration
# ----------------------------------------------------------------------------
# Copy to .env:   cp .env.example .env
#
# How this file works:
#   • Commented lines (starting with #) are IGNORED — the app / Docker Compose
#     falls back to the default shown next to each one. Uncomment a line to
#     override it.
#   • Only API_KEY is strictly required. Everything else is optional.
#   • .env is the single source of truth for both Docker and local runs.
# ============================================================================


# ── REQUIRED ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather.
API_KEY="YOUR_TELEGRAM_BOT_TOKEN_HERE"
# TELEGRAM_TOKEN is an accepted alias for API_KEY. In Docker it is derived from
# API_KEY automatically; set it only for a local run if you don't use API_KEY.
# TELEGRAM_TOKEN=

# Super-admin Telegram user IDs (integers; get yours from @userinfobot).
# Enables /broadcast and receives `make notify` links. Leave blank to disable.
ADMIN1=
ADMIN2=


# ── DATABASE ─────────────────────────────────────────────────────────────────

# SQLite (default) or PostgreSQL DSN.
#   Docker default: sqlite:////app/data/rollcall.db   (persisted to ./data)
#   Local  default: sqlite:///rollcall.db
#   Postgres:       postgresql://user:password@host:5432/rollcall
# DATABASE_URL=postgresql://user:password@host:5432/rollcall

# In-memory SQLite — all data lost on restart (original v1 behaviour).
# Overrides DATABASE_URL when true. Default: false
# MEMORY_MODE=false

# PostgreSQL connection pool bounds (ignored for SQLite).
# DB_POOL_MINCONN=1
# DB_POOL_MAXCONN=5


# ── BOT RUNTIME ──────────────────────────────────────────────────────────────

# Timezone for logs and scheduling. Default: Asia/Kolkata
# TZ=Asia/Kolkata

# Health-check endpoint. HEALTH_CHECK_HOST_PORT is the port published ON THE
# HOST — change this if 8080 is already taken by another container/service.
# HEALTH_CHECK_PORT is the port inside the container; leave it at 8080.
# HEALTH_CHECK_HOST_PORT=8090
# HEALTH_CHECK_PORT=8080

# Webhook mode: set to your public HTTPS URL to switch off long-polling.
# Leave unset (default) for long-polling.
# WEBHOOK_URL=https://yourdomain.com/webhook


# ── WEB APP / MINI APP / REST API ────────────────────────────────────────────

# Turn on the FastAPI server (required for web voting, Mini App, admin, portal).
# Default: false
# REST_API_ENABLED=true

# REST API bind + port. Docker default host 0.0.0.0 (so the tunnel can reach it);
# local default 127.0.0.1. Default port 8081.
# REST_API_PORT=8081
# REST_API_HOST=0.0.0.0

# Public HTTPS base URL — enables web voting links in panels and /weblink.
# `make up` auto-detects the Cloudflare tunnel URL and writes this for you.
# WEB_BASE_URL=https://your-domain-or-tunnel-url

# Public URL of the Mini App (usually <WEB_BASE_URL>/miniapp/) — sets the
# Telegram menu button on startup. Leave unset to disable the button.
# MINIAPP_URL=https://your-domain-or-tunnel-url/miniapp/


# ── WEB PUSH (VAPID) ─────────────────────────────────────────────────────────

# Keys for browser push notifications. If unset, a pair is generated on first
# use and stored in the DB. Set explicitly to keep push subscriptions valid
# across DB moves / server migrations.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=


# ── SECURITY (REST API) ──────────────────────────────────────────────────────

# Comma-separated allowed CORS origins. Default: *  (any origin)
# Tighten to your web origin in production, e.g. https://your-domain
# CORS_ALLOWED_ORIGINS=*

# Per-client rate limit for the REST API. Defaults: 60 requests / 60 seconds.
# REST_API_RATE_LIMIT_WINDOW_SECONDS=60
# REST_API_RATE_LIMIT_MAX_REQUESTS=60


# ── LOGGING & ERROR REPORTING ────────────────────────────────────────────────

# Emit one-line JSON logs for aggregators. Default: false (plain text)
# STRUCTURED_LOGS=false

# Sentry error reporting (requires the optional sentry-sdk dependency).
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.0
# RELEASE_VERSION=
# ENVIRONMENT=production


# ── BACKUPS (db-backup sidecar) ──────────────────────────────────────────────

# Daily SQLite backup rotation (see scripts/backup_db.sh).
# BACKUP_RETENTION_DAYS=7
# BACKUP_INTERVAL_SECONDS=86400


# ── CLOUDFLARE TUNNEL ────────────────────────────────────────────────────────

# For a STABLE named tunnel, set the token here and switch the cloudflared
# command in docker-compose.yml to the named-tunnel form. Leave unset to use
# the quick tunnel (random URL each restart).
# CLOUDFLARE_TUNNEL_TOKEN=
